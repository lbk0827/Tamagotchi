{
  "name": "ai-pet",
  "version": "0.1.0",
  "description": "Desktop floating AI tamagotchi",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build": "npm run build:main && npm run build:renderer && node scripts-copy-assets.mjs",
    "watch:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "watch:renderer": "tsc -p tsconfig.renderer.json --watch --preserveWatchOutput",
    "watch:ts": "concurrently -k \"npm:watch:main\" \"npm:watch:renderer\"",
    "watch:assets": "node scripts-copy-assets.mjs && chokidar \"src/renderer/index.html\" \"src/renderer/styles.css\" -c \"node scripts-copy-assets.mjs\" --polling --interval 400",
    "dev:electron": "wait-on dist/main/main.js dist/renderer/index.html && nodemon --legacy-watch --watch dist/main --watch dist/renderer --ext js,html,css --signal SIGTERM --exec \"electron .\"",
    "dev": "concurrently -k \"npm:watch:ts\" \"npm:watch:assets\" \"npm:dev:electron\"",
    "start": "electron ."
  },
  "keywords": [
    "electron",
    "tamagotchi",
    "ai-pet"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "electron-store": "^11.0.2"
  }
}
